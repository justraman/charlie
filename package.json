{
  "name": "charlie",
  "version": "0.0.0",
  "private": true,
  "description": "Open-source E2E and load testing for any web application.",
  "license": "Apache-2.0",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "packageManager": "bun@1.3.13",
  "scripts": {
    "dev": "bun run --cwd apps/web dev",
    "build": "bun run --cwd apps/web build",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "bun run --cwd apps/web typecheck",
    "test": "bun test",
    "db:migrate:local": "bun run --cwd apps/web db:migrate:local",
    "db:migrate:remote": "bun run --cwd apps/web db:migrate:remote"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.9",
    "typescript": "^5.7.3"
  }
}
