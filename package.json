{
  "name": "charlie",
  "version": "0.0.0",
  "private": true,
  "description": "Open-source E2E and load testing for any web application.",
  "license": "Apache-2.0",
  "type": "module",
  "packageManager": "bun@1.3.13",
  "scripts": {
    "dev": "bun run --cwd apps/web dev",
    "build": "nx run @charlie/web:build",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "nx run-many -t typecheck",
    "test": "nx run-many -t test",
    "affected": "nx affected -t typecheck test build",
    "graph": "nx graph",
    "db:generate": "bun run --cwd apps/web db:generate",
    "db:migrate:local": "bun run --cwd apps/web db:migrate:local",
    "db:migrate:remote": "bun run --cwd apps/web db:migrate:remote"
  },
  "dependencies": {
    "@auth/core": "0.35.3",
    "@hono/auth-js": "^1.1.1",
    "drizzle-orm": "0.45.2",
    "esbuild": "^0.28.1",
    "hono": "^4.12.30",
    "jose": "^6.2.3",
    "playwright-core": "^1.61.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.1",
    "user": "^0.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.9",
    "@cloudflare/workers-types": "^5.20260716.1",
    "@types/k6": "^2.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^9.1.2",
    "drizzle-kit": "0.31.10",
    "nx": "^23.1.0",
    "typescript": "^5.7.3",
    "vite": "^8.1.5",
    "wrangler": "^4.111.0"
  }
}
