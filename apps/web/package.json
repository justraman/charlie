{
  "name": "@charlie/web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n worker,spa -c blue,magenta \"wrangler dev\" \"vite\"",
    "dev:worker": "wrangler dev",
    "dev:spa": "vite",
    "build": "vite build",
    "preview": "wrangler dev",
    "deploy": "vite build && wrangler deploy",
    "deploy:dry": "wrangler deploy --dry-run",
    "typecheck": "tsc --noEmit -p tsconfig.app.json && tsc --noEmit -p tsconfig.worker.json",
    "cf-typegen": "wrangler types",
    "db:migrate:local": "wrangler d1 migrations apply charlie-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply charlie-db --remote"
  },
  "dependencies": {
    "@charlie/flow-core": "workspace:*",
    "hono": "^4.12.30",
    "jose": "^6.2.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260716.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^9.1.2",
    "vite": "^8.1.5",
    "wrangler": "^4.111.0"
  }
}
