# Charlie Worker secrets — copy to apps/web/.dev.vars for local dev.
# In production these are set with `wrangler secret put <NAME>`.

# --- Local dev login (no external IdP) ---
# Set this to sign in locally without a Google OAuth client. Enables
# GET /api/auth/dev (and a "Dev login" button on the login page), which mints a
# session for this email. First user becomes owner, same as real login.
# Local-only: it 404s unless set, and refuses when COOKIE_SECURE="true". Keep it
# in .dev.vars only — never `wrangler secret put` it.
DEV_LOGIN_EMAIL="you@example.com"
# Role for that user, applied on every dev login. Default "owner" (full access).
# Set to viewer|editor|admin to exercise RBAC locally.
DEV_LOGIN_ROLE="owner"

# --- Google OIDC (Phase 1) — optional locally if DEV_LOGIN_EMAIL is set ---
# Create an OAuth 2.0 Web client in Google Cloud Console.
# Authorized redirect URI: http://localhost:8787/api/auth/google/callback (dev)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# --- Key-encryption key (Phase 1+) ---
# 32-byte key, base64. Generate: `openssl rand -base64 32`
# Encrypts environment secrets / provider keys at rest (AES-GCM).
CHARLIE_KEK=""

# --- App configuration ---
# Public origin the SPA + OIDC redirect are served from.
APP_BASE_URL="http://localhost:8787"
# Set to "true" to require the Secure cookie flag (production). Leave empty in local dev over http.
COOKIE_SECURE=""

# --- Run callback token (Phase 3) ---
# Signs short-lived, run-scoped tokens the compute plane uses for callbacks.
# Generate: `openssl rand -base64 32`. Falls back to CHARLIE_KEK if unset.
CHARLIE_RUN_TOKEN_SECRET=""

# Absent locally → workflow dispatch is skipped (simulate the runner instead).
# GITHUB_APP_ID=""
# GITHUB_APP_PRIVATE_KEY=""          # PKCS#8 PEM (keep newlines)
# GITHUB_INSTALLATION_ID=""
# GITHUB_WEBHOOK_SECRET=""
# GITHUB_RUNNER_REPO="your-org/charlie-runner"
# GITHUB_RUNNER_REF="main"
# RUNNER_WORKFLOW_FILE="charlie-run.yml"

# R2_ACCOUNT_ID=""
# R2_ACCESS_KEY_ID=""
# R2_SECRET_ACCESS_KEY=""
# R2_BUCKET="charlie-artifacts"

# --- Slack (Phase 6) — not required for Phase 1 ---
# Both SLACK_BOT_TOKEN and SLACK_SIGNING_SECRET must be set for Slack to be
# "configured"; if either is absent, /charlie slash commands 401 and run
# reports to Slack are skipped. Credentials come from a single-workspace Slack
# app (see docs/SLACK.md). Set locally in apps/web/.dev.vars; in production use
# `wrangler secret put <NAME>`.
# Bot User OAuth Token (starts with xoxb-). Slack app → OAuth & Permissions.
# SLACK_BOT_TOKEN=""
# Signing Secret. Slack app → Basic Information → App Credentials.
# SLACK_SIGNING_SECRET=""
# Optional: pin inbound requests to one workspace (Txxxxxxxx). When set, requests
# from any other team_id are rejected. Leave unset to accept the app's workspace.
# SLACK_TEAM_ID=""
# Local/dev only: point Slack Web API calls at a mock. Never set in production.
# SLACK_API_BASE=""
